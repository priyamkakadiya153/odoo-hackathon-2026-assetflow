<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Category List View -->
    <record id="view_category_tree" model="ir.ui.view">
        <field name="name">assetflow.category.tree</field>
        <field name="model">assetflow.category</field>
        <field name="arch" type="xml">
            <tree string="Asset Categories">
                <field name="name"/>
                <field name="description"/>
                <field name="warranty_period"/>
                <field name="status" widget="badge" decoration-success="status == 'active'" decoration-danger="status == 'inactive'"/>
            </tree>
        </field>
    </record>

    <!-- Category Form View -->
    <record id="view_category_form" model="ir.ui.view">
        <field name="name">assetflow.category.form</field>
        <field name="model">assetflow.category</field>
        <field name="arch" type="xml">
            <form string="Asset Category">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Electronics"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="warranty_period" placeholder="Coverage length (months)"/>
                            <field name="status" widget="radio" options="{'horizontal': true}"/>
                        </group>
                        <group>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description_page">
                            <field name="description" placeholder="Provide category descriptions..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Category Search View -->
    <record id="view_category_filter" model="ir.ui.view">
        <field name="name">assetflow.category.select</field>
        <field name="model">assetflow.category</field>
        <field name="arch" type="xml">
            <search string="Search Categories">
                <field name="name" string="Category"/>
                <separator/>
                <filter string="Active Only" name="active_status" domain="[('status', '=', 'active')]"/>
                <filter string="Inactive Only" name="inactive_status" domain="[('status', '=', 'inactive')]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
</odoo>
