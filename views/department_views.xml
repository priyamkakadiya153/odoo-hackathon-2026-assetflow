<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Department List View -->
    <record id="view_department_tree" model="ir.ui.view">
        <field name="name">assetflow.department.tree</field>
        <field name="model">assetflow.department</field>
        <field name="arch" type="xml">
            <tree string="Departments">
                <field name="code"/>
                <field name="name"/>
                <field name="head_id"/>
                <field name="parent_id"/>
                <field name="status" widget="badge" decoration-success="status == 'active'" decoration-danger="status == 'inactive'"/>
            </tree>
        </field>
    </record>

    <!-- Department Form View -->
    <record id="view_department_form" model="ir.ui.view">
        <field name="name">assetflow.department.form</field>
        <field name="model">assetflow.department</field>
        <field name="arch" type="xml">
            <form string="Department">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Information Technology"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" placeholder="e.g. IT"/>
                            <field name="parent_id" placeholder="Parent Hierarchy (optional)"/>
                        </group>
                        <group>
                            <field name="head_id" widget="many2one_avatar_user"/>
                            <field name="status" widget="radio" options="{'horizontal': true}"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Department Search View -->
    <record id="view_department_filter" model="ir.ui.view">
        <field name="name">assetflow.department.select</field>
        <field name="model">assetflow.department</field>
        <field name="arch" type="xml">
            <search string="Search Departments">
                <field name="name" string="Department" filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="code"/>
                <field name="head_id"/>
                <separator/>
                <filter string="Active Only" name="active_status" domain="[('status', '=', 'active')]"/>
                <filter string="Inactive Only" name="inactive_status" domain="[('status', '=', 'inactive')]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Parent Department" name="group_parent" context="{'group_by': 'parent_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
