<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <!-- Extension of the main Dashboard template to append audit widgets -->
    <t t-inherit="assetflow.DashboardTemplate" t-inherit-mode="extension">
        <!-- Part 1: Add Audit KPI Cards -->
        <xpath expr="//div[hasclass('o_kpi_grid')]" position="inside">
            <div class="o_kpi_card">
                <div class="o_kpi_icon_wrapper blue">
                    <i class="oi oi-check"></i>
                </div>
                <div class="o_kpi_details">
                    <span class="o_kpi_value">6</span>
                    <span class="o_kpi_label">Total Audit Cycles</span>
                </div>
            </div>
            <div class="o_kpi_card">
                <div class="o_kpi_icon_wrapper yellow">
                    <i class="oi oi-clock"></i>
                </div>
                <div class="o_kpi_details">
                    <span class="o_kpi_value">1</span>
                    <span class="o_kpi_label">Audits In Progress</span>
                </div>
            </div>
            <div class="o_kpi_card">
                <div class="o_kpi_icon_wrapper green">
                    <i class="oi oi-check-circle"></i>
                </div>
                <div class="o_kpi_details">
                    <span class="o_kpi_value">5</span>
                    <span class="o_kpi_label">Completed Audits</span>
                </div>
            </div>
            <div class="o_kpi_card">
                <div class="o_kpi_icon_wrapper red">
                    <i class="oi oi-alert"></i>
                </div>
                <div class="o_kpi_details">
                    <span class="o_kpi_value">2</span>
                    <span class="o_kpi_label">Missing Assets</span>
                </div>
            </div>
            <div class="o_kpi_card">
                <div class="o_kpi_icon_wrapper orange">
                    <i class="oi oi-alert"></i>
                </div>
                <div class="o_kpi_details">
                    <span class="o_kpi_value">3</span>
                    <span class="o_kpi_label">Damaged Assets</span>
                </div>
            </div>
        </xpath>

        <!-- Part 2 & 3: Add Audit Status Summary & Report Preview -->
        <xpath expr="//div[hasclass('o_dashboard_maintenance_grid')]" position="after">
            <div class="o_dashboard_audit_grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-top: 20px;">
                <!-- Audit Report Preview -->
                <section class="o_audit_report_section" style="background: var(--o-view-background, #ffffff); padding: 20px; border-radius: 6px; border: 1px solid #dee2e6;">
                    <h2 class="o_section_title" style="font-size: 1.1rem; font-weight: 600; margin-bottom: 15px; color: #495057;">Audit Report Preview</h2>
                    
                    <div class="table-responsive">
                        <table class="table table-sm" style="width: 100%; font-size: 0.85rem; border-collapse: collapse; margin-bottom: 0;">
                            <thead>
                                <tr style="border-bottom: 2px solid #dee2e6; text-align: left; color: #6c757d;">
                                    <th style="padding: 6px 0;">Cycle</th>
                                    <th style="padding: 6px 0;">Department</th>
                                    <th style="padding: 6px 0;">Auditor</th>
                                    <th style="padding: 6px 0;">Audited</th>
                                    <th style="padding: 6px 0;">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr style="border-bottom: 1px solid #dee2e6;">
                                    <td style="padding: 8px 0; font-weight: 600; color: #007bff;">AUD-0021</td>
                                    <td style="padding: 8px 0;">Engineering</td>
                                    <td style="padding: 8px 0;">Kaizan</td>
                                    <td style="padding: 8px 0; font-weight: 600;">45 <span style="font-weight: normal; color: #6c757d; font-size: 0.75rem;">(38/2/5)</span></td>
                                    <td style="padding: 8px 0;"><span class="badge bg-success" style="font-size: 0.7rem; padding: 2px 4px; border-radius: 3px; color: white;">Completed</span></td>
                                </tr>
                                <tr style="border-bottom: 1px solid #dee2e6;">
                                    <td style="padding: 8px 0; font-weight: 600; color: #007bff;">AUD-0022</td>
                                    <td style="padding: 8px 0;">Operations</td>
                                    <td style="padding: 8px 0;">Priyam</td>
                                    <td style="padding: 8px 0; font-weight: 600;">30 <span style="font-weight: normal; color: #6c757d; font-size: 0.75rem;">(30/0/0)</span></td>
                                    <td style="padding: 8px 0;"><span class="badge bg-success" style="font-size: 0.7rem; padding: 2px 4px; border-radius: 3px; color: white;">Completed</span></td>
                                </tr>
                                <tr style="border-bottom: 1px solid #dee2e6;">
                                    <td style="padding: 8px 0; font-weight: 600; color: #007bff;">AUD-0023</td>
                                    <td style="padding: 8px 0;">QA / Testing</td>
                                    <td style="padding: 8px 0;">John Doe</td>
                                    <td style="padding: 8px 0; font-weight: 600;">12 <span style="font-weight: normal; color: #6c757d; font-size: 0.75rem;">(10/1/1)</span></td>
                                    <td style="padding: 8px 0;"><span class="badge bg-info text-dark" style="font-size: 0.7rem; padding: 2px 4px; border-radius: 3px;">In Progress</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- Audit Status Summary Widget -->
                <section class="o_audit_status_section" style="background: var(--o-view-background, #ffffff); padding: 20px; border-radius: 6px; border: 1px solid #dee2e6;">
                    <h2 class="o_section_title" style="font-size: 1.1rem; font-weight: 600; margin-bottom: 15px; color: #495057;">Audit Status Summary</h2>
                    
                    <div class="o_status_summary_list" style="display: flex; flex-direction: column; gap: 12px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 8px; border-bottom: 1px solid #f8f9fa;">
                            <span style="font-weight: 600; color: #495057;">Verified Assets</span>
                            <span class="badge bg-success" style="font-size: 0.85rem; padding: 4px 8px; border-radius: 4px; font-weight: bold; color: white;">82%</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 8px; border-bottom: 1px solid #f8f9fa;">
                            <span style="font-weight: 600; color: #495057;">Missing Assets</span>
                            <span class="badge bg-danger" style="font-size: 0.85rem; padding: 4px 8px; border-radius: 4px; font-weight: bold; color: white;">3%</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 8px; border-bottom: 1px solid #f8f9fa;">
                            <span style="font-weight: 600; color: #495057;">Damaged Assets</span>
                            <span class="badge bg-warning text-dark" style="font-size: 0.85rem; padding: 4px 8px; border-radius: 4px; font-weight: bold;">5%</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-weight: 600; color: #495057;">Pending Verification</span>
                            <span class="badge bg-info text-dark" style="font-size: 0.85rem; padding: 4px 8px; border-radius: 4px; font-weight: bold;">10%</span>
                        </div>
                    </div>
                </section>
            </div>
        </xpath>
    </t>
</templates>
