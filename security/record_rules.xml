<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ==================== Department Record Rules ==================== -->
        
        <!-- Employees: Read active departments only -->
        <record id="rule_department_employee" model="ir.rule">
            <field name="name">Employee Department View Restrictions</field>
            <field name="model_id" ref="model_assetflow_department"/>
            <field name="domain_force">[('status', '=', 'active')]</field>
            <field name="groups" eval="[(4, ref('group_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Department Heads: Modify active departments -->
        <record id="rule_department_dept_head" model="ir.rule">
            <field name="name">Department Head Access Rules</field>
            <field name="model_id" ref="model_assetflow_department"/>
            <field name="domain_force">[('status', '=', 'active')]</field>
            <field name="groups" eval="[(4, ref('group_dept_head'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ==================== User Profile Record Rules ==================== -->

        <!-- Employees: Read/Write own res.users profile only -->
        <record id="rule_employee_profile_self" model="ir.rule">
            <field name="name">Employee Profile Self Access</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="domain_force">[('id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Department Heads: Access department employee profiles -->
        <record id="rule_dept_head_profile_department" model="ir.rule">
            <field name="name">Department Head Employee Profile Access</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="domain_force">['|', ('id', '=', user.id), ('department_id', '=', user.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_dept_head'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
